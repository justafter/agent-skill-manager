{
  "name": "agent-skill-manager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local-first manager for Agent Skills and project agent rules.",
  "bin": {
    "asm": "./dist/cli/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "dev:server": "tsx src/server/index.ts",
    "dev:web": "vite --config web/vite.config.ts",
    "build": "tsc -p tsconfig.json && tsc -p web/tsconfig.json && vite build --config web/vite.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p web/tsconfig.json --noEmit",
    "test": "node --test --import tsx tests/integration/*.test.ts",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@tanstack/react-query": "^5.0.0",
    "chokidar": "^3.6.0",
    "commander": "^12.0.0",
    "diff": "^5.2.0",
    "express": "^4.19.0",
    "gray-matter": "^4.0.3",
    "pino": "^9.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.23.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/diff": "^5.2.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0"
  }
}
